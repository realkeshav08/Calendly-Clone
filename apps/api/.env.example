# Postgres connection string (Neon in production, local/Neon in dev).
DATABASE_URL="postgresql://user:password@host/dbname?sslmode=require"

# Server
NODE_ENV=development
PORT=4000

# Auth is stubbed: this is the seeded demo user's id (printed by `pnpm seed`).
DEFAULT_USER_ID="paste-after-seeding"

# CORS: the frontend origin allowed to call this API.
FRONTEND_URL="http://localhost:3000"

# Optional — email notifications (Resend). Leave unset to disable email gracefully.
RESEND_API_KEY=""
EMAIL_FROM="Calendly Clone <onboarding@resend.dev>"
